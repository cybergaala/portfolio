---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  banner?: string;
  slug?: string;
  related?: CollectionEntry<'blog'>[];
  lang?: Lang;
  translationUrl?: string;
  basePath?: string;
}

const { title, description, pubDate, tags, banner, slug, related, lang = 'en', translationUrl, basePath = '/blog' } = Astro.props;
const t = useTranslations(lang);

const dateLocale = lang === 'es' ? 'es-ES' : 'en-US';
const formatted = pubDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — Edgar Mejía`} description={description} lang={lang}>
  <div id="reading-progress-bar" aria-hidden="true"></div>
  <article class="post-article">
    <div class="page-container">
      <a href={basePath} class="back-link">{t('blog.back')}</a>

      <header class="post-header">
        <p class="section-label">
          {formatted}
          <span class="reading-time-sep">·</span>
          <span id="reading-time" class="reading-time-label" data-label={t('blog.min-read')}></span>
        </p>
        <h1 class="post-title">{title}</h1>
        <p class="post-desc">{description}</p>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="post-tag">{tag}</span>)}
          </div>
        )}
        {translationUrl && (
          <p class="lang-switcher">
            {lang === 'en'
              ? <><strong>ENG</strong>{' | '}<a href={translationUrl}>SPA</a></>
              : <><a href={translationUrl}>ENG</a>{' | '}<strong>SPA</strong></>
            }
          </p>
        )}
      </header>

      {banner && (
        <div class="post-banner">
          <img src={banner} alt="" role="presentation" />
        </div>
      )}

      <div class="post-layout">
        <div class="post-body">
          <slot />
        </div>
        <aside class="post-toc" id="toc-aside">
          <p class="toc-label">{t('blog.on-this-page')}</p>
          <nav id="toc"></nav>
        </aside>
      </div>

      <div class="post-end">
        <span class="post-end-marker" aria-hidden="true">· · ·</span>
        <button id="back-to-top" class="back-to-top">↑ {t('blog.back-to-top')}</button>
      </div>

      {related && related.length > 0 && (
        <section class="related-posts">
          <p class="section-label">{t('blog.related')}</p>
          <div class="related-list">
            {related.map(p => (
              <a href={`${basePath}/${p.slug.replace(/^(en|es)\//, '')}`} class="related-item">
                <p class="related-title">{p.data.title}</p>
                <p class="related-desc">{p.data.description}</p>
                {p.data.tags && (
                  <div class="post-tags">
                    {p.data.tags.map(t => <span class="post-tag">{t}</span>)}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</Layout>

<style>
  #reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: #111;
    z-index: 9999;
    transition: width 0.1s linear;
    transform-origin: left;
  }

  :global(html.dark) #reading-progress-bar {
    background: #f0f0f0;
  }

  .reading-time-sep {
    margin: 0 0.4em;
    opacity: 0.4;
  }

  .reading-time-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
  }

  :global(html.dark) .reading-time-label {
    color: rgba(255,255,255,0.3);
  }

  .post-article {
    padding: 8rem 0 8rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: rgba(0,0,0,0.35);
    text-decoration: none;
    margin-bottom: 3rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #111;
  }

  .lang-switcher {
    display: block;
    margin-top: 1.25rem;
    margin-left: auto;
    width: fit-content;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: rgba(0,0,0,0.35);
    text-transform: uppercase;
  }

  .lang-switcher strong {
    font-weight: 700;
    color: #111;
  }

  .lang-switcher a {
    color: rgba(0,0,0,0.35);
    text-decoration: none;
    transition: color 0.2s;
  }

  .lang-switcher a:hover {
    color: #111;
  }

  .post-header {
    border-bottom: 1px solid rgba(0,0,0,0.07);
    padding-bottom: 3rem;
    margin-bottom: 3.5rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin: 0 0 1.25rem 0;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: #111;
    margin: 0 0 1rem 0;
  }

  .post-desc {
    font-size: 1.05rem;
    color: rgba(0,0,0,0.45);
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    border: 1px solid rgba(0,0,0,0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  /* Layout: content + TOC */
  .post-layout {
    display: grid;
    grid-template-columns: 42rem 1fr;
    gap: 0 4rem;
    align-items: start;
  }

  /* TOC */
  .post-toc {
    position: sticky;
    top: 5rem;
  }

  .toc-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin: 0 0 1rem 0;
  }

  #toc :global(a) {
    display: block;
    font-size: 0.82rem;
    color: rgba(0,0,0,0.35);
    text-decoration: none;
    padding: 0.3rem 0;
    border-left: 1px solid rgba(0,0,0,0.08);
    padding-left: 0.875rem;
    transition: color 0.15s, border-color 0.15s;
    line-height: 1.4;
  }

  #toc :global(a:hover) {
    color: #111;
  }

  #toc :global(a.active) {
    color: #111;
    border-left-color: #111;
  }

  @media (max-width: 900px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-toc {
      display: none;
    }
  }

  /* Body */
  .post-body {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(0,0,0,0.65);
    min-width: 0;
    text-align: justify;
    hyphens: auto;
  }

  .post-body :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111;
    margin: 2.5rem 0 0.75rem;
  }

  .post-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: #111;
    margin: 2rem 0 0.5rem;
  }

  .post-body :global(p) {
    margin: 0 0 1.25rem 0;
  }

  .post-body :global(> p:first-of-type::first-letter) {
    float: left;
    font-size: 4.5em;
    line-height: 0.8;
    font-weight: 700;
    margin: 0.05em 0.1em 0 0;
    color: #111;
    letter-spacing: -0.02em;
  }

  :global(html.dark) .post-body :global(> p:first-of-type::first-letter) {
    color: #f0f0f0;
  }

  .post-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin: 0 0 1.25rem 0;
  }

  .post-body :global(ul li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .post-body :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0.1rem;
    top: 0.65em;
    width: 4px;
    height: 4px;
    background: rgba(0,0,0,0.22);
    border-radius: 50%;
  }

  .post-body :global(ol) {
    padding-left: 1.25rem;
    margin: 0 0 1.25rem 0;
  }

  .post-body :global(ol li) {
    margin-bottom: 0.5rem;
  }

  .post-body :global(ol li::marker) {
    color: rgba(0,0,0,0.22);
  }

  .post-body :global(strong) {
    font-weight: 600;
    color: rgba(0,0,0,0.75);
  }

  .post-body :global(a) {
    color: #111;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    opacity: 0.6;
  }

  .post-body :global(code) {
    font-family: 'Geist Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: rgba(0,0,0,0.04);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: #111;
  }

  .post-body :global(pre) {
    background: rgba(0,0,0,0.04);
    border: 1px solid rgba(0,0,0,0.07);
    padding: 1.25rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 0 0 1.5rem 0;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid rgba(0,0,0,0.12);
    margin: 0 0 1.25rem 0;
    padding: 0.1rem 0 0.1rem 1.25rem;
    color: rgba(0,0,0,0.45);
    font-style: italic;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.07);
    margin: 2.5rem 0;
  }

  .post-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 2rem 0;
    border: 1px solid rgba(0,0,0,0.07);
    transition: filter 0.5s ease;
  }

  /* Image followed by blockquote → render blockquote as caption */
  .post-body :global(p:has(img):has(+ blockquote)) {
    margin-bottom: 0;
  }

  .post-body :global(p:has(img):has(+ blockquote) img) {
    margin-bottom: 0;
    border-radius: 4px 4px 0 0;
  }

  .post-body :global(p:has(img) + blockquote) {
    border-left: none;
    padding: 0.5rem 0.875rem 0.6rem;
    font-style: normal;
    font-size: 0.8rem;
    color: rgba(0,0,0,0.4);
    text-align: center;
    margin-top: 0;
    margin-bottom: 2rem;
    background: rgba(0,0,0,0.025);
    border-radius: 0 0 4px 4px;
    border: 1px solid rgba(0,0,0,0.07);
    border-top: none;
  }

  .post-body :global(p:has(img) + blockquote p) {
    margin: 0;
  }

  /* Banner */
  .post-banner {
    width: 100%;
    aspect-ratio: 12 / 5.9;
    overflow: hidden;
    border-radius: 6px;
    margin-bottom: 3.5rem;
    border: 1px solid rgba(0,0,0,0.07);
  }

  .post-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.5s ease;
  }

  :global(html.dark) .post-banner { border-color: rgba(255, 255, 255, 0.08); }

  :global(.img-blur-load) {
    filter: blur(20px) !important;
    will-change: filter;
  }

  /* Header */
  :global(html.dark) .back-link { color: rgba(255, 255, 255, 0.35); }
  :global(html.dark) .back-link:hover { color: #f0f0f0; }
  :global(html.dark) .lang-switcher { color: rgba(255, 255, 255, 0.35); }
  :global(html.dark) .lang-switcher strong { color: #f0f0f0; }
  :global(html.dark) .lang-switcher a { color: rgba(255, 255, 255, 0.35); }
  :global(html.dark) .lang-switcher a:hover { color: #f0f0f0; }
  :global(html.dark) .post-header { border-bottom-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .section-label { color: rgba(255, 255, 255, 0.3); }
  :global(html.dark) .post-title { color: #f0f0f0; }
  :global(html.dark) .post-desc { color: rgba(255, 255, 255, 0.45); }
  :global(html.dark) .post-tag {
    color: rgba(255, 255, 255, 0.3);
    border-color: rgba(255, 255, 255, 0.1);
  }

  /* TOC */
  :global(html.dark) .toc-label { color: rgba(255, 255, 255, 0.3); }
  :global(html.dark) #toc :global(a) {
    color: rgba(255, 255, 255, 0.35);
    border-left-color: rgba(255, 255, 255, 0.08);
  }
  :global(html.dark) #toc :global(a:hover) { color: #f0f0f0; }
  :global(html.dark) #toc :global(a.active) {
    color: #f0f0f0;
    border-left-color: #f0f0f0;
  }

  /* Body */
  :global(html.dark) .post-body { color: rgba(255, 255, 255, 0.65); }
  :global(html.dark) .post-body :global(h2) { color: #f0f0f0; }
  :global(html.dark) .post-body :global(h3) { color: #f0f0f0; }
  :global(html.dark) .post-body :global(strong) { color: rgba(255, 255, 255, 0.8); }
  :global(html.dark) .post-body :global(a) { color: #f0f0f0; }
  :global(html.dark) .post-body :global(code) {
    background: rgba(255, 255, 255, 0.07);
    color: #f0f0f0;
  }
  :global(html.dark) .post-body :global(pre) {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global(html.dark) .post-body :global(pre code) {
    background: none;
    color: inherit;
  }

  :global(html.dark) .post-body :global(pre .line) {
    background-color: transparent !important;
  }
  :global(html.dark) .post-body :global(ul li::before) {
    background: rgba(255,255,255,0.2);
  }

  :global(html.dark) .post-body :global(ol li::marker) {
    color: rgba(255,255,255,0.2);
  }

  :global(html.dark) .post-body :global(blockquote) {
    border-left-color: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.45);
  }

  :global(html.dark) .post-body :global(p:has(img) + blockquote) {
    background: rgba(255,255,255,0.03);
    border-color: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.35);
  }
  :global(html.dark) .post-body :global(hr) { border-top-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .post-body :global(img) { border-color: rgba(255, 255, 255, 0.08); }

  /* Related posts */
  .related-posts {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(0,0,0,0.07);
    max-width: 42rem;
  }

  .related-list {
    display: flex;
    flex-direction: column;
  }

  .related-item {
    display: block;
    padding: 1.75rem 0;
    border-top: 1px solid rgba(0,0,0,0.06);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .related-item:first-child {
    border-top: none;
  }

  .related-item:hover {
    opacity: 0.6;
  }

  .related-title {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #111;
    margin: 0 0 0.3rem 0;
    line-height: 1.3;
  }

  .related-desc {
    font-size: 0.875rem;
    color: rgba(0,0,0,0.45);
    line-height: 1.6;
    margin: 0 0 0.75rem 0;
  }

  .post-end {
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-top: 4rem;
  }

  .back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 4px;
    background: transparent;
    color: rgba(0,0,0,0.35);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .back-to-top:hover {
    color: #111;
    border-color: rgba(0,0,0,0.3);
  }

  :global(html.dark) .back-to-top {
    border-color: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.35);
  }

  :global(html.dark) .back-to-top:hover {
    color: #f0f0f0;
    border-color: rgba(255,255,255,0.35);
  }

  .post-end-marker {
    font-size: 1rem;
    letter-spacing: 0.4em;
    color: rgba(0,0,0,0.18);
    user-select: none;
  }

  :global(html.dark) .post-end-marker { color: rgba(255,255,255,0.18); }


  :global(html.dark) .related-posts { border-top-color: rgba(255,255,255,0.08); }
  :global(html.dark) .related-item { border-top-color: rgba(255,255,255,0.06); }
  :global(html.dark) .related-title { color: #f0f0f0; }
  :global(html.dark) .related-desc { color: rgba(255,255,255,0.45); }
</style>

<script>
  function initReadingTime() {
    const body = document.querySelector('.post-body');
    const el = document.getElementById('reading-time');
    if (!body || !el) return;
    const label = el.dataset.label ?? 'min read';
    const words = (body.textContent ?? '').trim().split(/\s+/).filter(Boolean).length;
    const minutes = Math.max(1, Math.round(words / 200));
    el.textContent = `${minutes} ${label}`;
  }

  function initProgressBar() {
    const bar = document.getElementById('reading-progress-bar');
    if (!bar) return;

    const update = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = `${Math.min(100, progress)}%`;
    };

    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  function initToc() {
    const toc = document.getElementById('toc');
    const headings = document.querySelectorAll<HTMLHeadingElement>('.post-body h2');

    if (!toc) return;

    toc.innerHTML = '';

    if (headings.length === 0) {
      const aside = document.getElementById('toc-aside');
      if (aside) aside.style.display = 'none';
      return;
    }

    const aside = document.getElementById('toc-aside');
    if (aside) aside.style.display = '';

    headings.forEach((h, i) => {
      if (!h.id) h.id = `heading-${i}`;
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      toc.appendChild(a);
    });

    const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('a'));

    const setActive = () => {
      let current = headings[0];
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= 120) current = h;
      }
      links.forEach(a => {
        a.classList.toggle('active', a.getAttribute('href') === `#${current.id}`);
      });
    };

    window.addEventListener('scroll', setActive, { passive: true });
    setActive();
  }

  function initBackToTop() {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;
    btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }

  function initBlurUp() {
    const images = document.querySelectorAll<HTMLImageElement>('.post-banner img, .post-body img');
    images.forEach(img => {
      if (img.complete && img.naturalWidth > 0) return;
      img.classList.add('img-blur-load');
      const reveal = () => img.classList.remove('img-blur-load');
      img.addEventListener('load', reveal, { once: true });
      img.addEventListener('error', reveal, { once: true });
    });
  }

  document.addEventListener('astro:page-load', () => {
    initToc();
    initReadingTime();
    initProgressBar();
    initBackToTop();
    initBlurUp();
  });
</script>

---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — Edgar Mejía`} description={description}>
  <article class="post-article">
    <div class="page-container">
      <a href="/blog" class="back-link">← Blog</a>

      <header class="post-header">
        <p class="section-label">{formatted}</p>
        <h1 class="post-title">{title}</h1>
        <p class="post-desc">{description}</p>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="post-tag">{tag}</span>)}
          </div>
        )}
      </header>

      <div class="post-layout">
        <div class="post-body">
          <slot />
        </div>
        <aside class="post-toc" id="toc-aside">
          <p class="toc-label">On this page</p>
          <nav id="toc"></nav>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .post-article {
    padding: 8rem 0 8rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: rgba(0,0,0,0.35);
    text-decoration: none;
    margin-bottom: 3rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #111;
  }

  .post-header {
    border-bottom: 1px solid rgba(0,0,0,0.07);
    padding-bottom: 3rem;
    margin-bottom: 3.5rem;
    max-width: 42rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin: 0 0 1.25rem 0;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: #111;
    margin: 0 0 1rem 0;
  }

  .post-desc {
    font-size: 1.05rem;
    color: rgba(0,0,0,0.45);
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    border: 1px solid rgba(0,0,0,0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  /* Layout: content + TOC */
  .post-layout {
    display: grid;
    grid-template-columns: 42rem 1fr;
    gap: 0 4rem;
    align-items: start;
  }

  /* TOC */
  .post-toc {
    position: sticky;
    top: 5rem;
  }

  .toc-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin: 0 0 1rem 0;
  }

  #toc :global(a) {
    display: block;
    font-size: 0.82rem;
    color: rgba(0,0,0,0.35);
    text-decoration: none;
    padding: 0.3rem 0;
    border-left: 1px solid rgba(0,0,0,0.08);
    padding-left: 0.875rem;
    transition: color 0.15s, border-color 0.15s;
    line-height: 1.4;
  }

  #toc :global(a:hover) {
    color: #111;
  }

  #toc :global(a.active) {
    color: #111;
    border-left-color: #111;
  }

  @media (max-width: 900px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-toc {
      display: none;
    }
  }

  /* Body */
  .post-body {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(0,0,0,0.65);
    min-width: 0;
  }

  .post-body :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111;
    margin: 2.5rem 0 0.75rem;
  }

  .post-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: #111;
    margin: 2rem 0 0.5rem;
  }

  .post-body :global(p) {
    margin: 0 0 1.25rem 0;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.25rem;
    margin: 0 0 1.25rem 0;
  }

  .post-body :global(li) {
    margin-bottom: 0.35rem;
  }

  .post-body :global(strong) {
    font-weight: 600;
    color: rgba(0,0,0,0.75);
  }

  .post-body :global(a) {
    color: #111;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    opacity: 0.6;
  }

  .post-body :global(code) {
    font-family: 'Geist Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: rgba(0,0,0,0.04);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: #111;
  }

  .post-body :global(pre) {
    background: rgba(0,0,0,0.04);
    border: 1px solid rgba(0,0,0,0.07);
    padding: 1.25rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 0 0 1.5rem 0;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid rgba(0,0,0,0.12);
    margin: 0 0 1.25rem 0;
    padding: 0.1rem 0 0.1rem 1.25rem;
    color: rgba(0,0,0,0.45);
    font-style: italic;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.07);
    margin: 2.5rem 0;
  }

  .post-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 2rem 0;
    border: 1px solid rgba(0,0,0,0.07);
  }

  /* Header */
  :global(html.dark) .back-link { color: rgba(255, 255, 255, 0.35); }
  :global(html.dark) .back-link:hover { color: #f0f0f0; }
  :global(html.dark) .post-header { border-bottom-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .section-label { color: rgba(255, 255, 255, 0.3); }
  :global(html.dark) .post-title { color: #f0f0f0; }
  :global(html.dark) .post-desc { color: rgba(255, 255, 255, 0.45); }
  :global(html.dark) .post-tag {
    color: rgba(255, 255, 255, 0.3);
    border-color: rgba(255, 255, 255, 0.1);
  }

  /* TOC */
  :global(html.dark) .toc-label { color: rgba(255, 255, 255, 0.3); }
  :global(html.dark) #toc :global(a) {
    color: rgba(255, 255, 255, 0.35);
    border-left-color: rgba(255, 255, 255, 0.08);
  }
  :global(html.dark) #toc :global(a:hover) { color: #f0f0f0; }
  :global(html.dark) #toc :global(a.active) {
    color: #f0f0f0;
    border-left-color: #f0f0f0;
  }

  /* Body */
  :global(html.dark) .post-body { color: rgba(255, 255, 255, 0.65); }
  :global(html.dark) .post-body :global(h2) { color: #f0f0f0; }
  :global(html.dark) .post-body :global(h3) { color: #f0f0f0; }
  :global(html.dark) .post-body :global(strong) { color: rgba(255, 255, 255, 0.8); }
  :global(html.dark) .post-body :global(a) { color: #f0f0f0; }
  :global(html.dark) .post-body :global(code) {
    background: rgba(255, 255, 255, 0.07);
    color: #f0f0f0;
  }
  :global(html.dark) .post-body :global(pre) {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
  }
  :global(html.dark) .post-body :global(blockquote) {
    border-left-color: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.45);
  }
  :global(html.dark) .post-body :global(hr) { border-top-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .post-body :global(img) { border-color: rgba(255, 255, 255, 0.08); }
</style>

<script>
  const toc = document.getElementById('toc');
  const headings = document.querySelectorAll<HTMLHeadingElement>('.post-body h2');

  if (toc && headings.length > 0) {
    headings.forEach((h, i) => {
      if (!h.id) h.id = `heading-${i}`;
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      toc.appendChild(a);
    });

    const links = toc.querySelectorAll<HTMLAnchorElement>('a');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = toc.querySelector<HTMLAnchorElement>(`a[href="#${id}"]`);
          if (link) link.classList.toggle('active', entry.isIntersecting);
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );

    headings.forEach(h => observer.observe(h));
  } else if (toc) {
    document.getElementById('toc-aside')!.style.display = 'none';
  }
</script>

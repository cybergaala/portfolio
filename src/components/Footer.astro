<style>
  .site-footer {
    border-top: 1px solid rgba(0,0,0,0.07);
    padding: 6rem 0 3rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin: 0 0 2.5rem 0;
  }

  .footer-name {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #111;
    line-height: 1.05;
    margin: 0 0 3rem 0;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-links {
    display: flex;
    gap: 1.75rem;
  }

  .footer-links a {
    font-size: 0.82rem;
    color: rgba(0,0,0,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #111;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(0,0,0,0.25);
  }

  :global(html.dark) .site-footer { border-top-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .section-label { color: rgba(255, 255, 255, 0.3); }
  :global(html.dark) .footer-name { color: #f0f0f0; }
  :global(html.dark) .footer-links a { color: rgba(255, 255, 255, 0.4); }
  :global(html.dark) .footer-links a:hover { color: #f0f0f0; }
  :global(html.dark) .footer-copy { color: rgba(255, 255, 255, 0.25); }
</style>

---
---

<header>
  <nav id="mainNav">
    <div class="nav-inner page-container">
      <a href="/" class="nav-logo"><span class="nav-logo-box">EM</span></a>
      <ul class="nav-links">
        <li><a href="/#experience">Experience</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
      <a href="/blog" class="nav-blog">Blog</a>
      <button id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    padding: 0;
    z-index: 10;
    transition: border-bottom 0.2s;
  }

  nav.nav-scrolled {
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 52px;
  }

  .nav-logo {
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .nav-logo-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #111;
    border: 1.5px solid #111;
    padding: 0 6px;
    line-height: 1.6;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-logo:hover .nav-logo-box {
    background: #111;
    color: #fff;
    opacity: 1;
  }

  .nav-links {
    list-style: none;
    margin: 0 auto 0 2rem;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-links li {
    display: flex;
    align-items: center;
  }

  .nav-links a,
  .nav-blog {
    display: flex;
    align-items: center;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(0,0,0,0.5);
    padding: 0 14px;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-blog:hover {
    color: #111;
  }

  .nav-blog {
    padding-right: 0;
    font-weight: 400;
    color: rgba(0,0,0,0.5);
  }

  #theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    margin-left: 16px;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(0,0,0,0.45);
    border-radius: 50%;
    transition: color 0.2s, background 0.2s;
    flex-shrink: 0;
    padding: 0;
  }

  #theme-toggle:hover {
    color: #111;
    background: rgba(0,0,0,0.06);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }

  /* Solid fallback during theme transition — backdrop-filter can't render inside view-transition snapshots */
  :global(html[data-theme-transition]) nav.nav-scrolled {
    background-color: rgba(255, 255, 255, 0.97);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition: none;
  }
  :global(html[data-theme-transition].dark) nav.nav-scrolled {
    background-color: rgba(15, 18, 25, 0.97);
  }

  /* Dark mode styles */
  :global(html.dark) nav.nav-scrolled {
    background-color: rgba(15, 18, 25, 0.85);
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  :global(html.dark) .nav-logo-box {
    color: #f0f0f0;
    border-color: #f0f0f0;
  }

  :global(html.dark) .nav-logo:hover .nav-logo-box {
    background: #f0f0f0;
    color: #111;
  }

  :global(html.dark) .nav-links a,
  :global(html.dark) .nav-blog {
    color: rgba(255, 255, 255, 0.45);
  }

  :global(html.dark) .nav-links a:hover,
  :global(html.dark) .nav-blog:hover {
    color: #f0f0f0;
  }

  :global(html.dark) #theme-toggle {
    color: rgba(255, 255, 255, 0.5);
  }

  :global(html.dark) #theme-toggle:hover {
    color: #f0f0f0;
    background: rgba(255, 255, 255, 0.08);
  }

  :global(html.dark) .icon-sun { display: block; }
  :global(html.dark) .icon-moon { display: none; }
</style>

<script>
  // Scroll handler always looks up a fresh DOM reference so it works
  // correctly after ViewTransitions swaps the page body.
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('mainNav');
    if (nav) nav.classList.toggle('nav-scrolled', window.scrollY > 0);
  });

  function initHeader() {
    const mainNav = document.getElementById('mainNav');
    const toggleBtn = document.getElementById('theme-toggle');
    const html = document.documentElement;

    // Re-apply scroll class immediately in case the page loaded while scrolled.
    if (mainNav) mainNav.classList.toggle('nav-scrolled', window.scrollY > 0);

    if (!toggleBtn) return;

    toggleBtn.addEventListener('click', () => {
      const isDark = html.classList.contains('dark');
      const rect = toggleBtn.getBoundingClientRect();
      const cx = Math.round(rect.left + rect.width / 2);
      const cy = Math.round(rect.top + rect.height / 2);

      html.style.setProperty('--theme-x', cx + 'px');
      html.style.setProperty('--theme-y', cy + 'px');

      const applyTheme = () => {
        if (isDark) {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
      };

      if (!('startViewTransition' in document)) {
        applyTheme();
        return;
      }

      html.dataset.themeTransition = 'true';
      const t = (document as any).startViewTransition(applyTheme);
      t.finished.finally(() => {
        delete html.dataset.themeTransition;
      });
    });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>

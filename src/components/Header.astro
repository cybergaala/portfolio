---
---

<header>
  <nav id="mainNav">
    <div class="nav-inner page-container">
      <a href="/" class="nav-logo"><span class="nav-logo-box">EM</span></a>
      <ul class="nav-links">
        <li><a href="/#experience">Experience</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
      <a href="/blog" class="nav-blog">Blog</a>
    </div>
  </nav>
</header>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    padding: 0;
    z-index: 10;
    transition: border-bottom 0.2s;
  }

  nav.nav-scrolled {
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 52px;
  }

  .nav-logo {
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .nav-logo-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #111;
    border: 1.5px solid #111;
    padding: 0 6px;
    line-height: 1.6;
  }

  .nav-logo:hover .nav-logo-box {
    opacity: 0.5;
  }

  .nav-links {
    list-style: none;
    margin: 0 auto 0 2rem;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-links li {
    display: flex;
    align-items: center;
  }

  .nav-links a,
  .nav-blog {
    display: flex;
    align-items: center;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(0,0,0,0.5);
    padding: 0 14px;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-blog:hover {
    color: #111;
  }

  .nav-blog {
    padding-right: 0;
    font-weight: 400;
    color: rgba(0,0,0,0.5);
  }

  .nav-logo-box {
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-logo:hover .nav-logo-box {
    background: #111;
    color: #fff;
  }

  @media (prefers-color-scheme: dark) {
    nav.nav-scrolled {
      background-color: rgba(15, 18, 25, 0.85);
      border-bottom-color: rgba(255, 255, 255, 0.08);
    }

    .nav-logo-box {
      color: #f0f0f0;
      border-color: #f0f0f0;
    }

    .nav-logo:hover .nav-logo-box {
      background: #f0f0f0;
      color: #111;
    }

    .nav-links a,
    .nav-blog {
      color: rgba(255, 255, 255, 0.45);
    }

    .nav-links a:hover,
    .nav-blog:hover {
      color: #f0f0f0;
    }
  }
</style>

<script is:browser>
  const mainNav = document.getElementById("mainNav");

  window.addEventListener("scroll", () => {
    mainNav.classList.toggle("nav-scrolled", window.scrollY > 0);
  });
</script>

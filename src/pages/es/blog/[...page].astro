---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/ui';

const t = useTranslations('es');

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const posts = (await getCollection('blog', ({ id, data }) => id.startsWith('es/') && !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
const posts = page.data;
---

<Layout title={t('blog.writing')} description={t('blog.writing-description')} lang="es">
  <section class="section-blog-listing">
    <div class="page-container">
      <p class="section-label">Blog</p>
      <div class="post-list">
        {posts.map((post, i) => {
          const num = String((page.currentPage - 1) * page.size + i + 1).padStart(2, '0');
          const date = post.data.pubDate.toLocaleDateString('es-ES', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <a href={`/es/blog/${post.slug.replace('es/', '')}`} class="post-item">
              <span class="post-num">{num}</span>
              <div class="post-info">
                <p class="post-title">{post.data.title}</p>
                <p class="post-meta">{date}</p>
                <p class="post-desc">{post.data.description}</p>
              </div>
            </a>
          );
        })}
      </div>

      {page.lastPage > 1 && (
        <nav class="pagination">
          {page.url.prev ? (
            <a href={page.url.prev} class="page-link">{t('blog.prev')}</a>
          ) : (
            <span class="page-link disabled">{t('blog.prev')}</span>
          )}

          <div class="page-numbers">
            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(n => (
              <a
                href={n === 1 ? '/es/blog' : `/es/blog/${n}`}
                class={`page-num ${n === page.currentPage ? 'active' : ''}`}
              >
                {n}
              </a>
            ))}
          </div>

          {page.url.next ? (
            <a href={page.url.next} class="page-link">{t('blog.next')}</a>
          ) : (
            <span class="page-link disabled">{t('blog.next')}</span>
          )}
        </nav>
      )}
    </div>
  </section>
</Layout>

<style>
  .section-blog-listing {
    padding: 10rem 0 8rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin: 0 0 2.5rem 0;
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(0,0,0,0.07);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .post-item:last-child {
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }

  .post-item:hover {
    opacity: 0.6;
  }

  .post-num {
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1;
    color: rgba(0,0,0,0.06);
    letter-spacing: -0.03em;
    user-select: none;
    flex-shrink: 0;
    width: 5rem;
    text-align: right;
  }

  .post-info {
    padding-top: 0.6rem;
  }

  .post-title {
    font-size: 1.75rem;
    font-weight: 600;
    color: #111;
    letter-spacing: -0.02em;
    margin: 0 0 0.3rem 0;
    line-height: 1.2;
  }

  .post-meta {
    font-size: 0.82rem;
    color: rgba(0,0,0,0.35);
    margin: 0 0 0.9rem 0;
  }

  .post-desc {
    font-size: 0.95rem;
    color: rgba(0,0,0,0.55);
    line-height: 1.7;
    margin: 0;
    max-width: 56ch;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.07);
  }

  .page-link {
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(0,0,0,0.5);
    text-decoration: none;
    transition: color 0.15s;
  }

  .page-link:not(.disabled):hover {
    color: #111;
  }

  .page-link.disabled {
    opacity: 0.25;
    cursor: default;
  }

  .page-numbers {
    display: flex;
    gap: 0.25rem;
  }

  .page-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(0,0,0,0.4);
    text-decoration: none;
    border-radius: 3px;
    transition: color 0.15s, background 0.15s;
  }

  .page-num:hover {
    color: #111;
    background: rgba(0,0,0,0.04);
  }

  .page-num.active {
    color: #111;
    background: rgba(0,0,0,0.06);
    font-weight: 600;
  }

  :global(html.dark) .section-label { color: rgba(255, 255, 255, 0.3); }
  :global(html.dark) .post-item { border-top-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .post-item:last-child { border-bottom-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .post-num { color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .post-title { color: #f0f0f0; }
  :global(html.dark) .post-meta { color: rgba(255, 255, 255, 0.35); }
  :global(html.dark) .post-desc { color: rgba(255, 255, 255, 0.55); }
  :global(html.dark) .pagination { border-top-color: rgba(255, 255, 255, 0.08); }
  :global(html.dark) .page-link { color: rgba(255, 255, 255, 0.4); }
  :global(html.dark) .page-link:not(.disabled):hover { color: #f0f0f0; }
  :global(html.dark) .page-num { color: rgba(255, 255, 255, 0.4); }
  :global(html.dark) .page-num:hover { color: #f0f0f0; background: rgba(255,255,255,0.05); }
  :global(html.dark) .page-num.active { color: #f0f0f0; background: rgba(255,255,255,0.08); }
</style>

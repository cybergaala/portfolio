---
import Layout from "../layouts/Layout.astro";
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout
  title="Edgar Mejía - Portfolio"
  description="Personal portfolio of Edgar Mejía, software developer from El Salvador."
  lang="en"
>
  <section class="section-about">
    <div class="page-container">
      <p class="section-label">About me</p>
      <h1 class="about-h1">
        <span>Hi there 👋!</span>
        <span>I'm Edgar Mejía,</span>
        <span class="about-sub">a <span class="gitch-text"></span></span>
        <span class="about-last">from El Salvador 🇸🇻</span>
      </h1>
    </div>
  </section>
  <section id="writing" class="section-writing">
    <div class="page-container">
      <p class="section-label">Latest posts</p>
      <div class="post-list">
        {posts.map((post, i) => {
          const num = String(i + 1).padStart(2, '0');
          const date = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug}`} class="post-item">
              <span class="post-num">{num}</span>
              <p class="post-title">{post.data.title}</p>
              <p class="post-meta">{date}</p>
              <p class="post-desc">{post.data.description}</p>
            </a>
          );
        })}
      </div>
      {posts.length > 0 && (
        <a href="/blog" class="all-posts-link">All posts →</a>
      )}
    </div>
  </section>

  <section id="experience" class="section-experience">
    <div class="page-container">
      <p class="section-label">Experience</p>
      <div class="exp-list">

        <div class="exp-item">
          <span class="exp-num">01</span>
          <div class="exp-info">
            <p class="exp-company">PBS El Salvador</p>
            <p class="exp-meta">Senior Mobile Developer &nbsp;·&nbsp; 2024 — Present</p>
            <p class="exp-desc">Lead mobile engineer across Android, iOS, and Flutter, owning the full lifecycle of multiple consumer-facing apps from architecture decisions to App Store and Play Store releases. Introduced a shared Flutter module strategy that cut duplicate logic between platforms by roughly 60%, and established code review practices that brought the team's average review cycle from three days down to one. Also serve as the technical reference for mobile decisions across the organization, collaborating directly with product and QA to ship faster without accumulating debt.</p>
          </div>
        </div>

        <div class="exp-item">
          <span class="exp-num">02</span>
          <div class="exp-info">
            <p class="exp-company">ThinkForward</p>
            <p class="exp-meta">Mid Full-Stack Developer &nbsp;·&nbsp; 2023 — 2024</p>
            <p class="exp-desc">Principal developer on a multi-tenant ERP system built from scratch with ASP.NET Core, Entity Framework, and SQL Server. Designed the database schema and API surface that serves several independent companies from a single codebase, using tenant-aware middleware and row-level data isolation. Delivered the Razor-based frontend alongside the backend, writing vanilla JavaScript for dynamic UI interactions without introducing a heavy framework. The system went from zero to production in under eight months and is still in active daily use.</p>
          </div>
        </div>

        <div class="exp-item">
          <span class="exp-num">03</span>
          <div class="exp-info">
            <p class="exp-company">Serfinsa</p>
            <p class="exp-meta">Mid Mobile Developer &nbsp;·&nbsp; 2018 — 2020</p>
            <p class="exp-desc">Android developer on a fintech platform serving thousands of daily transactions, working with Kotlin and early Jetpack Compose. Took ownership of the payments and transfers screens, refactoring a fragile XML-based UI to a composable architecture that made new flows significantly faster to build and test. Collaborated with backend and security teams to implement biometric authentication and PCI-compliant session handling, and contributed to the internal component library that the team still uses today.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="contact" class="section-contact">
    <div class="page-container">
      <p class="section-label">Contact</p>
      <h2 class="contact-heading">Let's work<br/>together.</h2>
      <form class="contact-form" name="contact" method="POST" netlify>
      <!-- <form class="contact-form" name="contact" netlify></form> -->
        <div class="form-row">
          <div class="form-field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
        </div>
        <div class="form-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" placeholder="Tell me about your project..." required></textarea>
        </div>
        <button type="submit" class="form-submit">Send message</button>
      </form>
    </div>
  </section>

  <style>
    .section {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 2rem;
      color: white;
      transition: background-color 0.5s ease;
    }

    .section:nth-child(odd) { background-color: #fff; }
    .section:nth-child(even) { background-color: #0d47a1; }

    .section.green {
      background-color: black;
      color: #fff;
      text-shadow: none;
    }

    .section.purple { background-color: #4a148c; }
    .section.red { background-color: #b71c1c; }
    .section.teal { background-color: #004d40; }
    
    .section-about {
      padding: 10rem 0 6rem;
    }

    .about-h1 {
      display: flex;
      flex-direction: column;
    }


    .section-about h1 {
      font-size: clamp(3rem, 7vw, 6rem);
    }

    .about-sub {
      color: rgba(0,0,0,0.35);
      white-space: nowrap;
    }

    h1 {
      color: #111;
      text-align: left;
      font-weight: 700;
      font-size: clamp(2rem, 4.5vw, 3.75rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0.25rem 0;
    }

    @keyframes typing {
      0.00%, 12.93%, 14.63% { content: ""; }
      0.85%, 12.24% { content: "J"; color: #f29111; }
      1.70%, 11.56% { content: "Ja"; color: #f29111; }
      2.55%, 10.88% { content: "Jav"; color: #f29111; }
      3.40%, 10.20% { content: "Java"; color: #f29111; }

      14.63%, 30.61%, 32.31% { content: ""; color: #ffd54a; }
      15.48%, 29.93% { content: "P"; color: #ffd54a; }
      16.33%, 29.25% { content: "Py"; color: #ffd54a; }
      17.18%, 28.57% { content: "Pyt"; color: #ffd54a; }
      18.03%, 27.89% { content: "Pyth"; color: #ffd54a; }
      18.88%, 27.21% { content: "Pytho"; color: #ffd54a; }
      19.73%, 26.53% { content: "Python"; color: #ffd54a; }

      32.31%, 45.24%, 46.94% { content: ""; color: #5732d6; }
      33.16%, 44.56% { content: "."; color: #5732d6; }
      34.01%, 43.88% { content: ".N"; color: #5732d6; }
      34.86%, 43.20% { content: ".Ne"; color: #5732d6; }
      35.71%, 42.52% { content: ".Net"; color: #5732d6; }

      46.94%, 61.39%, 63.09% { content: ""; color: #f05237; }
      47.79%, 60.71% { content: "S"; color: #f05237; }
      48.64%, 60.03% { content: "Sw"; color: #f05237; }
      49.49%, 59.35% { content: "Swi"; color: #f05237; }
      50.34%, 58.67% { content: "Swif"; color: #f05237; }
      51.19%, 57.99% { content: "Swift"; color: #f05237; }

      63.09%, 79.08%, 80.78% { content: ""; color: #8052ff; }
      63.94%, 78.40% { content: "K"; color: #8052ff; }
      64.79%, 77.72% { content: "Ko"; color: #8052ff; }
      65.64%, 77.04% { content: "Kot"; color: #8052ff; }
      66.49%, 76.36% { content: "Kotl"; color: #8052ff; }
      67.34%, 75.68% { content: "Kotli"; color: #8052ff; }
      68.20%, 75.00% { content: "Kotlin"; color: #8052ff; }

      80.78%, 98.30%, 100.00% { content: ""; color: #15cbfc; }
      81.63%, 97.62% { content: "F"; color: #15cbfc; }
      82.48%, 96.94% { content: "Fl"; color: #15cbfc; }
      83.33%, 96.26% { content: "Flu"; color: #15cbfc; }
      84.18%, 95.58% { content: "Flut"; color: #15cbfc; }
      85.03%, 94.90% { content: "Flutt"; color: #15cbfc; }
      85.88%, 94.22% { content: "Flutte"; color: #15cbfc; }
      86.73%, 93.54% { content: "Flutter"; color: #15cbfc; }
    }

    @keyframes blink {
      0%,
      100% { opacity: 1; }
      50% { opacity: 0; }
    }

    .typewriter {
      --caret: currentcolor;
      width: 150px;
      border-bottom: #000 solid 3px;
    }

    .typewriter::before {
      content: "";
      animation: typing 11.76s infinite;
    }

    .typewriter::after {
      content: "";
      border-right: 1px solid var(--caret);
      animation: blink 0.5s linear infinite;
    }

    .typewriter.thick::after { border-right: 1ch solid var(--caret); }
    .typewriter.nocaret::after { border-right: 0; }
    .thick {
      /* Add beautiful shadow */
      text-shadow: 0 0 10px rgba(255, 255, 255, 0.5), 0 0 20px rgba(255, 255, 255, 0.3);
    }

    @media (prefers-reduced-motion) {
      .typewriter::after { animation: none; }

      @keyframes sequencePopup {
          0.00%, 16.67% { content: "Java"; }
          16.67%, 33.33% { content: "Python"; }
          33.33%, 50.00% { content: ".Net"; }
          50.00%, 66.67% { content: "Swift"; }
          66.67%, 83.33% { content: "Kotlin"; }
          83.33%, 100.00% { content: "Flutter"; }
      }

      .typewriter::before {
        content: "Java";
        animation: sequencePopup 11.76s linear infinite;
      }
    }

    .typewriter {
      display: inline-block;
    }

    /* Writing section */
    .section-writing {
      padding: 6rem 0;
      border-top: 1px solid rgba(0,0,0,0.07);
    }

    .post-list {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0 3rem;
      border-top: 1px solid rgba(0,0,0,0.07);
    }

    .post-item {
      display: flex;
      flex-direction: column;
      padding: 2rem 0 0;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .post-item:hover {
      opacity: 0.6;
    }

    .post-num {
      font-size: 2.5rem;
      font-weight: 700;
      line-height: 1;
      color: rgba(0,0,0,0.06);
      letter-spacing: -0.03em;
      user-select: none;
      margin: 0 0 1.5rem 0;
    }

    .post-title {
      font-size: 1.05rem;
      font-weight: 600;
      color: #111;
      letter-spacing: -0.02em;
      margin: 0 0 0.5rem 0;
      line-height: 1.3;
    }

    .post-meta {
      font-size: 0.75rem;
      color: rgba(0,0,0,0.3);
      margin: 0 0 0.75rem 0;
      letter-spacing: 0.03em;
    }

    .post-desc {
      font-size: 0.875rem;
      color: rgba(0,0,0,0.5);
      line-height: 1.65;
      margin: 0;
    }

    .all-posts-link {
      display: inline-block;
      margin-top: 2rem;
      font-size: 0.82rem;
      font-weight: 500;
      color: rgba(0,0,0,0.35);
      text-decoration: none;
      letter-spacing: 0.03em;
      transition: color 0.2s;
    }

    .all-posts-link:hover {
      color: #111;
    }

    @media (max-width: 900px) {
      .post-list {
        grid-template-columns: repeat(2, 1fr);
        gap: 0 2rem;
      }
    }

    @media (max-width: 560px) {
      .post-list {
        grid-template-columns: 1fr;
      }

      .post-item {
        padding: 1.5rem 0 0;
        border-top: 1px solid rgba(0,0,0,0.07);
      }

      .post-list {
        border-top: none;
      }
    }

    /* Experience section */
    .section-experience {
      padding: 6rem 0;
      border-top: 1px solid rgba(0,0,0,0.07);
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.3);
      margin: 0 0 2.5rem 0;
    }

    .exp-list {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .exp-item {
      display: flex;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .exp-num {
      font-size: 4.5rem;
      font-weight: 700;
      line-height: 1;
      color: rgba(0,0,0,0.06);
      letter-spacing: -0.03em;
      user-select: none;
      flex-shrink: 0;
      width: 5rem;
      text-align: right;
    }

    .exp-info {
      padding-top: 0.6rem;
    }

    .exp-company {
      font-size: 1.75rem;
      font-weight: 600;
      color: #111;
      letter-spacing: -0.02em;
      margin: 0 0 0.3rem 0;
    }

    .exp-meta {
      font-size: 0.82rem;
      color: rgba(0,0,0,0.35);
      margin: 0 0 0.9rem 0;
    }

    .exp-desc {
      font-size: 0.95rem;
      color: rgba(0,0,0,0.55);
      line-height: 1.7;
      margin: 0;
      max-width: 62ch;
    }

    /* Contact section */
    .section-contact {
      padding: 6rem 0 8rem;
      border-top: 1px solid rgba(0,0,0,0.07);
    }

    .contact-heading {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #111;
      margin: 0 0 3rem 0;
      line-height: 1.05;
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      max-width: 640px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .form-field label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.35);
    }

    .form-field input,
    .form-field textarea {
      background: none;
      border: none;
      border-bottom: 1px solid rgba(0,0,0,0.15);
      padding: 0.6rem 0;
      font-size: 0.95rem;
      color: #111;
      outline: none;
      resize: none;
      font-family: inherit;
      transition: border-color 0.2s;
    }

    .form-field input::placeholder,
    .form-field textarea::placeholder {
      color: rgba(0,0,0,0.2);
    }

    .form-field input:focus,
    .form-field textarea:focus {
      border-bottom-color: #111;
    }

    .form-submit {
      align-self: flex-start;
      background: #111;
      color: #fff;
      border: none;
      padding: 0.85rem 2rem;
      font-size: 0.85rem;
      font-family: inherit;
      font-weight: 500;
      letter-spacing: 0.04em;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .form-submit:hover {
      opacity: 0.75;
    }

    @media (max-width: 640px) {
      .form-row {
        grid-template-columns: 1fr;
      }
    }

    :global(html.dark) .section-about { border-bottom-color: rgba(255, 255, 255, 0.08); }
    :global(html.dark) h1 { color: #f0f0f0; }
    :global(html.dark) .about-sub { color: rgba(255, 255, 255, 0.35); }
    :global(html.dark) .typewriter { border-bottom-color: #f0f0f0; }

    /* Writing */
    :global(html.dark) .section-writing { border-top-color: rgba(255, 255, 255, 0.08); }
    :global(html.dark) .post-list { border-top-color: rgba(255, 255, 255, 0.08); }
    :global(html.dark) .post-num { color: rgba(255, 255, 255, 0.08); }
    :global(html.dark) .post-title { color: #f0f0f0; }
    :global(html.dark) .post-meta { color: rgba(255, 255, 255, 0.3); }
    :global(html.dark) .post-desc { color: rgba(255, 255, 255, 0.5); }
    :global(html.dark) .all-posts-link { color: rgba(255, 255, 255, 0.35); }
    :global(html.dark) .all-posts-link:hover { color: #f0f0f0; }
    :global(html.dark) .post-item { border-top-color: rgba(255, 255, 255, 0.08); }

    /* Experience */
    :global(html.dark) .section-experience { border-top-color: rgba(255, 255, 255, 0.08); }
    :global(html.dark) .section-label { color: rgba(255, 255, 255, 0.3); }
    :global(html.dark) .exp-num { color: rgba(255, 255, 255, 0.08); }
    :global(html.dark) .exp-company { color: #f0f0f0; }
    :global(html.dark) .exp-meta { color: rgba(255, 255, 255, 0.35); }
    :global(html.dark) .exp-desc { color: rgba(255, 255, 255, 0.55); }

    /* Contact */
    :global(html.dark) .section-contact { border-top-color: rgba(255, 255, 255, 0.08); }
    :global(html.dark) .contact-heading { color: #f0f0f0; }
    :global(html.dark) .form-field label { color: rgba(255, 255, 255, 0.35); }
    :global(html.dark) .form-field input,
    :global(html.dark) .form-field textarea {
      border-bottom-color: rgba(255, 255, 255, 0.15);
      color: #f0f0f0;
    }
    :global(html.dark) .form-field input::placeholder,
    :global(html.dark) .form-field textarea::placeholder { color: rgba(255, 255, 255, 0.2); }
    :global(html.dark) .form-field input:focus,
    :global(html.dark) .form-field textarea:focus { border-bottom-color: #f0f0f0; }
    :global(html.dark) .form-submit { background: #f0f0f0; color: #111; }
  </style>

  <style is:global>
    /* .dud { color: #c0c0c0 !important; } */
    /* .dud { color: #ee4e4e !important; } */
    .dud { color: #ee4e4e64 !important; }
  </style>
</Layout>

<script>
  // Thanks: https://codepen.io/soulwire/pen/mEMPrK

  class TextScramble {
    el: HTMLElement;
    chars: string;
    resolve!: () => void;
    queue: { from: string; to: string; start: number; end: number; char?: string }[] = [];
    frame: number = 0;
    frameRequest: number = 0;

    constructor(el: HTMLElement) {
      this.el = el;
      this.chars = '!<>-_\\/[]{}—=+*^?#火木中大小力__';
      this.update = this.update.bind(this);
    }

    setText(newText: string) {
      const oldText = Array.from(this.el.innerText);
      const newTextArr = Array.from(newText);
      const length = Math.max(oldText.length, newTextArr.length);
      const promise = new Promise<void>((resolve) => (this.resolve = resolve));
      this.queue = [];

      for (let i = 0; i < length; i++) {
        const from = oldText[i] || '';
        const to = newTextArr[i] || '';
        const start = Math.floor(Math.random() * 40);
        const end = start + Math.floor(Math.random() * 40);
        this.queue.push({ from, to, start, end });
      }

      cancelAnimationFrame(this.frameRequest);
      this.frame = 0;
      this.update();
      return promise;
    }

    update() {
      let output = '';
      let complete = 0;

      for (let i = 0, n = this.queue.length; i < n; i++) {
        let { from, to, start, end, char } = this.queue[i];
        if (this.frame >= end) {
          complete++;
          output += to;
        } else if (this.frame >= start) {
          if (!char || Math.random() < 0.28) {
            char = this.randomChar();
            this.queue[i].char = char;
          }
          output += `<span class="dud">${char}</span>`;
        } else {
          output += from;
        }
      }

      this.el.innerHTML = output;

      if (complete === this.queue.length) {
        this.resolve();
      } else {
        this.frameRequest = requestAnimationFrame(this.update);
        this.frame++;
      }
    }

    randomChar() {
      return this.chars[Math.floor(Math.random() * this.chars.length)];
    }
  }

  const phrases = [
    'Java hater ☕',
    'Python dev 🐍',
    '.Net dev',
    'Swift dev',
    'Kotlin lover',
    'Flutter dev',
    'JS enthusiast',
    'TS fan or hater?',
    'Web dev',
    'OW2 player 🧡',
    'Coffee hater :)',
    'Pre-AI dev 🗿',
    'Coke lover 🥤',
    'Girl dad 👧🏻',
    'Cat lover 🐱',
  ];

  function initScramble() {
    const el = document.querySelector<HTMLElement>('.gitch-text');
    if (!el) return;

    const fx = new TextScramble(el);
    let lastIndex = -1;

    const next = () => {
      let randomIndex: number;
      do {
        randomIndex = Math.floor(Math.random() * phrases.length);
      } while (randomIndex === lastIndex);

      lastIndex = randomIndex;
      fx.setText(phrases[randomIndex]).then(() => {
        setTimeout(next, 1200);
      });
    };

    next();
  }

  document.addEventListener('astro:page-load', initScramble);
</script>
---
import Layout from "../layouts/Layout.astro";
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ id, data }) => id.startsWith('en/') && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<Layout
  title="Edgar Mejía - Portfolio"
  description="Personal portfolio of Edgar Mejía, software developer from El Salvador."
  lang="en"
>
  <section class="section-about">
    <div class="page-container">
      <p class="section-label">About me</p>
      <h1 class="about-h1">
        <span>Hi there 👋!</span>
        <span>I'm Edgar Mejía,</span>
        <span class="about-sub"><span class="gitch-text"></span></span>
        <span class="about-last">from El Salvador 🇸🇻</span>
      </h1>
      <a href="/about" class="about-link">More about me →</a>
    </div>
  </section>
  <section id="writing" class="section-writing">
    <div class="page-container">
      <p class="section-label">Latest posts</p>
      <div class="post-list">
        {posts.map((post, i) => {
          const num = String(i + 1).padStart(2, '0');
          const date = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug.replace('en/', '')}`} class="post-item">
              <span class="post-num">{num}</span>
              <p class="post-title">{post.data.title}</p>
              <p class="post-meta">{date}</p>
              <p class="post-desc">{post.data.description}</p>
            </a>
          );
        })}
      </div>
      {posts.length > 0 && (
        <a href="/blog" class="all-posts-link">All posts →</a>
      )}
    </div>
  </section>

  <section id="experience" class="section-experience">
    <div class="page-container">
      <p class="section-label">Experience</p>
      <div class="exp-list">

        <div class="exp-item">
          <span class="exp-num">01</span>
          <div class="exp-info">
            <p class="exp-company">PBS El Salvador</p>
            <p class="exp-meta">Mid Mobile Developer &nbsp;·&nbsp; Mar 2024 — Present</p>
            <p class="exp-desc">Working across Android and iOS — native development with Kotlin and Swift, plus Flutter for shared cross-platform features.</p>
          </div>
        </div>

        <div class="exp-item">
          <span class="exp-num">02</span>
          <div class="exp-info">
            <p class="exp-company">ThinkForward</p>
            <p class="exp-meta">Mid Full-stack Developer &nbsp;·&nbsp; Sep 2023 — Apr 2024</p>
            <p class="exp-desc">Led C# development on a multi-company ERP built from scratch — ASP.NET Core, Entity Framework, SQL Server, Razor, and vanilla JavaScript.</p>
          </div>
        </div>

        <div class="exp-item">
          <span class="exp-num">03</span>
          <div class="exp-info">
            <p class="exp-company">Serfinsa</p>
            <p class="exp-meta">Mid Mobile Developer &nbsp;·&nbsp; Oct 2023 — Mar 2024</p>
            <p class="exp-desc">Android developer on a fintech app, building screens with Kotlin and Jetpack Compose.</p>
          </div>
        </div>

        <div class="exp-item">
          <span class="exp-num">04</span>
          <div class="exp-info">
            <p class="exp-company">Hightech Consulting</p>
            <p class="exp-meta">Mid Mobile Developer &nbsp;·&nbsp; Jul 2022 — Aug 2023</p>
            <p class="exp-desc">Mobile developer across iOS (Swift), Android (Kotlin/Java), and Flutter on multiple client projects, applying MVVM and Clean Architecture.</p>
          </div>
        </div>

      </div>
      <a href="/experience" class="all-exp-link">Full experience →</a>
    </div>
  </section>

  <section id="contact" class="section-contact">
    <div class="page-container">
      <p class="section-label">Contact</p>
      <h2 class="contact-heading">Let's work<br/>together.</h2>
      <form class="contact-form" id="contact-form" name="contact" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="contact" />
        <div class="form-row">
          <div class="form-field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
        </div>
        <div class="form-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" placeholder="Tell me about your project..." required></textarea>
        </div>
        <button type="submit" class="form-submit">Send message</button>
      </form>
      <div id="contact-success" style="display:none;" class="contact-success">
        <p>Thanks! I'll get back to you soon.</p>
      </div>
    </div>
  </section>


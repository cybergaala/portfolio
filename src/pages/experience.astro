---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Experience — Edgar Mejía"
  description="Work history and professional experience of Edgar Mejía, software developer from El Salvador."
  lang="en"
>
  <div class="experience-page">
    <div class="page-container">

      <section class="intro-section">
        <p class="section-label">Experience</p>
        <h1 class="page-heading">Where I've<br/>worked.</h1>
        <p class="page-sub">Eight years building mobile and web products across fintech, ERP, and consumer apps.</p>
      </section>

      <section class="jobs-section">

        <div class="job-item">
          <div class="job-meta">
            <span class="job-num">01</span>
            <p class="job-period">Mar 2024 — Present</p>
          </div>
          <div class="job-content">
            <div class="job-header">
              <p class="job-company">PBS El Salvador</p>
              <p class="job-role">Mid Mobile Developer · Full-time · Remote</p>
            </div>
            <p class="job-desc">
              Working across Android and iOS — native development with Kotlin and Swift, plus Flutter for shared cross-platform features.
            </p>
            <ul class="job-tags">
              <li>Android</li>
              <li>iOS</li>
              <li>Flutter</li>
              <li>Kotlin</li>
              <li>Swift</li>
            </ul>
          </div>
        </div>

        <div class="job-item">
          <div class="job-meta">
            <span class="job-num">02</span>
            <p class="job-period">Sep 2023 — Apr 2024</p>
          </div>
          <div class="job-content">
            <div class="job-header">
              <p class="job-company">ThinkForward</p>
              <p class="job-role">Mid Full-stack Developer · Contract · Remote</p>
            </div>
            <p class="job-desc">
              Led C# development on a multi-company ERP built from scratch. ASP.NET Core and Entity Framework
              on the backend, Razor and vanilla JavaScript on the frontend, SQL Server as the data layer.
            </p>
            <ul class="job-tags">
              <li>ASP.NET Core</li>
              <li>Entity Framework</li>
              <li>SQL Server</li>
              <li>Razor</li>
              <li>JavaScript</li>
            </ul>
          </div>
        </div>

        <div class="job-item">
          <div class="job-meta">
            <span class="job-num">03</span>
            <p class="job-period">Oct 2023 — Mar 2024</p>
          </div>
          <div class="job-content">
            <div class="job-header">
              <p class="job-company">Serfinsa</p>
              <p class="job-role">Mid Mobile Developer · Full-time · Hybrid</p>
            </div>
            <p class="job-desc">
              Android developer on a fintech app, building screens with Kotlin and Jetpack Compose.
            </p>
            <ul class="job-tags">
              <li>Kotlin</li>
              <li>Jetpack Compose</li>
              <li>Android</li>
              <li>GitLab</li>
            </ul>
          </div>
        </div>

        <div class="job-item">
          <div class="job-meta">
            <span class="job-num">04</span>
            <p class="job-period">Jul 2022 — Aug 2023</p>
          </div>
          <div class="job-content">
            <div class="job-header">
              <p class="job-company">Hightech Consulting</p>
              <p class="job-role">Mid Mobile Developer · Full-time · Remote</p>
            </div>
            <p class="job-desc">
              Mobile developer across multiple client projects covering iOS (Swift), Android (Kotlin/Java),
              and Flutter, applying MVVM and Clean Architecture throughout.
            </p>
            <ul class="job-tags">
              <li>Swift</li>
              <li>Kotlin</li>
              <li>Flutter</li>
              <li>iOS</li>
              <li>Firebase</li>
            </ul>
          </div>
        </div>

        <div class="job-item">
          <div class="job-meta">
            <span class="job-num">05</span>
            <p class="job-period">2018 — 2022</p>
          </div>
          <div class="job-content">
            <div class="job-header">
              <p class="job-company">Creativa Consultores</p>
              <p class="job-role">Full-time · 4 years 2 months</p>
            </div>
            <div class="job-subroles">
              <div class="subrole">
                <p class="subrole-title">Programmer Analyst — AES El Salvador <span class="subrole-period">Feb 2021 — Jul 2022</span></p>
                <p class="job-desc">Worked on the ACE Project as part of the Integration Team at AES El Salvador.</p>
                <ul class="job-tags">
                  <li>SQL Server</li>
                  <li>CSS</li>
                </ul>
              </div>
              <div class="subrole">
                <p class="subrole-title">Mid Full-stack Developer — Aeroman <span class="subrole-period">Mar 2021 — Jun 2021</span></p>
                <p class="job-desc">Built the BI-Embedded project for Aeroman — an Angular frontend connected to MicroStrategy for data visualization, with Spring Boot on the backend.</p>
                <ul class="job-tags">
                  <li>Angular</li>
                  <li>Spring Boot</li>
                  <li>MicroStrategy</li>
                </ul>
              </div>
              <div class="subrole">
                <p class="subrole-title">Mid Python Developer — AES El Salvador <span class="subrole-period">Mar 2020 — Feb 2021</span></p>
                <p class="job-desc">Main developer of the AES Virtual Agent, a chatbot connected to Slack, Facebook Messenger, and WhatsApp (via Twilio). Built with Python and Flask, using Dialogflow for NLU, GCP for hosting, and PostgreSQL and SQL Server as data stores.</p>
                <ul class="job-tags">
                  <li>Python</li>
                  <li>Flask</li>
                  <li>Dialogflow</li>
                  <li>GCP</li>
                  <li>PostgreSQL</li>
                </ul>
              </div>
              <div class="subrole">
                <p class="subrole-title">Jr. Full-stack Developer <span class="subrole-period">Jun 2018 — Feb 2020</span></p>
                <p class="job-desc">Part of the Innovation team, building and maintaining projects with new technologies and CI/CD pipelines. Also served as technical lead on internal and client-facing projects.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="job-item">
          <div class="job-meta">
            <span class="job-num">06</span>
            <p class="job-period">2019 — 2022</p>
          </div>
          <div class="job-content">
            <div class="job-header">
              <p class="job-company">Freelance</p>
              <p class="job-role">Self-employed · 2 years 11 months</p>
            </div>
            <p class="job-desc">Independent iOS and Android projects for various clients, working with native SDKs and Firebase.</p>
            <div class="job-subroles">
              <div class="subrole">
                <p class="subrole-title">Jr. iOS Developer <span class="subrole-period">May 2020 — Jun 2022</span></p>
              </div>
              <div class="subrole">
                <p class="subrole-title">Jr. Android Developer <span class="subrole-period">Aug 2019 — Jun 2022</span></p>
              </div>
            </div>
            <ul class="job-tags" style="margin-top:1rem">
              <li>iOS</li>
              <li>Android</li>
              <li>Firebase</li>
            </ul>
          </div>
        </div>

        <div class="job-item">
          <div class="job-meta">
            <span class="job-num">07</span>
            <p class="job-period">Mar 2018 — May 2018</p>
          </div>
          <div class="job-content">
            <div class="job-header">
              <p class="job-company">BetterRideInc</p>
              <p class="job-role">Jr. Full-stack Developer · Full-time</p>
            </div>
            <p class="job-desc">
              Part of a small team, shipping new features across the REST API and the web admin interface.
            </p>
          </div>
        </div>

      </section>

      <section class="cta-section">
        <p class="cta-text">Want to work together?</p>
        <a href="/#contact" class="cta-link">Get in touch →</a>
      </section>

    </div>
  </div>

  <style>
    .experience-page {
      padding-top: 6rem;
      padding-bottom: 8rem;
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.3);
      margin: 0 0 2rem 0;
    }

    /* Intro */
    .intro-section {
      padding: 4rem 0 5rem;
      border-bottom: 1px solid rgba(0,0,0,0.07);
    }

    .page-heading {
      font-size: clamp(3rem, 7vw, 6rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #111;
      line-height: 1.02;
      margin: 0 0 1.2rem 0;
    }

    .page-sub {
      font-size: 1rem;
      color: rgba(0,0,0,0.45);
      line-height: 1.6;
      max-width: 48ch;
      margin: 0;
    }

    /* Jobs */
    .jobs-section {
      padding: 0;
    }

    .job-item {
      display: grid;
      grid-template-columns: 9rem 1fr;
      gap: 3rem;
      padding: 4rem 0;
      border-bottom: 1px solid rgba(0,0,0,0.07);
    }

    .job-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      padding-top: 0.3rem;
      gap: 0.6rem;
    }

    .job-num {
      font-size: 3.5rem;
      font-weight: 700;
      line-height: 1;
      color: rgba(0,0,0,0.06);
      letter-spacing: -0.03em;
      user-select: none;
    }

    .job-period {
      font-size: 0.72rem;
      color: rgba(0,0,0,0.3);
      letter-spacing: 0.08em;
      white-space: nowrap;
      margin: 0;
    }

    .job-header {
      margin-bottom: 1.2rem;
    }

    .job-company {
      font-size: 1.75rem;
      font-weight: 600;
      color: #111;
      letter-spacing: -0.02em;
      margin: 0 0 0.2rem 0;
      line-height: 1.1;
    }

    .job-role {
      font-size: 0.85rem;
      color: rgba(0,0,0,0.35);
      margin: 0;
      letter-spacing: 0.02em;
    }

    .job-desc {
      font-size: 0.95rem;
      color: rgba(0,0,0,0.55);
      line-height: 1.75;
      max-width: 62ch;
      margin: 0 0 1.5rem 0;
    }

    .job-tags {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .job-tags li {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.35);
      border: 1px solid rgba(0,0,0,0.12);
      padding: 0.25rem 0.6rem;
    }

    .job-subroles {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-bottom: 1rem;
    }

    .subrole-title {
      font-size: 0.88rem;
      font-weight: 600;
      color: rgba(0,0,0,0.65);
      margin: 0 0 0.4rem 0;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.5rem;
    }

    .subrole-period {
      font-size: 0.72rem;
      font-weight: 400;
      color: rgba(0,0,0,0.3);
      letter-spacing: 0.05em;
    }

    /* CTA */
    .cta-section {
      padding: 5rem 0 0;
      display: flex;
      align-items: baseline;
      gap: 2rem;
    }

    .cta-text {
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: #111;
      margin: 0;
    }

    .cta-link {
      font-size: 0.82rem;
      font-weight: 500;
      color: rgba(0,0,0,0.35);
      text-decoration: none;
      letter-spacing: 0.03em;
      transition: color 0.2s;
    }

    .cta-link:hover {
      color: #111;
    }

    /* Responsive */
    @media (max-width: 640px) {
      .job-item {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .job-meta {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        padding-top: 0;
      }

      .job-num {
        font-size: 2.5rem;
      }

      .cta-section {
        flex-direction: column;
        gap: 0.8rem;
      }
    }

    /* Dark mode */
    :global(html.dark) .section-label { color: rgba(255,255,255,0.3); }
    :global(html.dark) .intro-section { border-bottom-color: rgba(255,255,255,0.08); }
    :global(html.dark) .page-heading { color: #f0f0f0; }
    :global(html.dark) .page-sub { color: rgba(255,255,255,0.45); }
    :global(html.dark) .job-item { border-bottom-color: rgba(255,255,255,0.08); }
    :global(html.dark) .job-num { color: rgba(255,255,255,0.06); }
    :global(html.dark) .job-period { color: rgba(255,255,255,0.3); }
    :global(html.dark) .job-company { color: #f0f0f0; }
    :global(html.dark) .job-role { color: rgba(255,255,255,0.35); }
    :global(html.dark) .job-desc { color: rgba(255,255,255,0.55); }
    :global(html.dark) .job-tags li {
      color: rgba(255,255,255,0.35);
      border-color: rgba(255,255,255,0.12);
    }
    :global(html.dark) .cta-text { color: #f0f0f0; }
    :global(html.dark) .cta-link { color: rgba(255,255,255,0.35); }
    :global(html.dark) .cta-link:hover { color: #f0f0f0; }
    :global(html.dark) .subrole-title { color: rgba(255,255,255,0.65); }
    :global(html.dark) .subrole-period { color: rgba(255,255,255,0.3); }
  </style>
</Layout>
